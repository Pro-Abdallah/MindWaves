```gitignore
# =========================================
# Visual Studio
# =========================================
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# =========================================
# Rider / JetBrains
# =========================================
.idea/

# =========================================
# VS Code
# =========================================
.vscode/

# =========================================
# Build Folders
# =========================================
bin/
obj/

# =========================================
# Logs
# =========================================
*.log
logs/

# =========================================
# Environment Files
# =========================================
.env
.env.*
!.env.example

# =========================================
# ASP.NET Publish Output
# =========================================
publish/

# =========================================
# NuGet
# =========================================
*.nupkg

# =========================================
# Database Files (Optional)
# =========================================
*.mdf
*.ldf
*.db

# =========================================
# OS Files
# =========================================
.DS_Store
Thumbs.db

# =========================================
# Temporary Files
# =========================================
tmp/
temp/

# =========================================
# Resharper
# =========================================
_ReSharper*/
*.DotSettings.user

# =========================================
# Test Results
# =========================================
TestResults/

# =========================================
# Coverage Reports
# =========================================
coverage/
coverage-results/

# =========================================
# Secrets
# =========================================
secrets.json
appsettings.Development.json
```
